# Copy this file to ".env" and fill in your values.

# MongoDB Atlas connection string.
# Atlas → Database → Connect → Drivers → copy the string.
# Replace <password> and add your DB name (e.g. /gatetracker) before the "?".
MONGODB_URI=mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/gatetracker?retryWrites=true&w=majority

# Port (optional, defaults to 3000). Render sets this automatically.
PORT=3000
